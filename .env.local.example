# Email Configuration for Contact Form
# 1. Create a file named .env.local in this directory
# 2. Add the following lines to it, replacing the values with your own
# 3. DO NOT commit .env.local to git (it is already in .gitignore)

# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Your Gmail App Password
# To generate one:
# 1. Go to your Google Account > Security
# 2. Enable 2-Step Verification if not already enabled
# 3. Search for "App Passwords" in the search bar at the top
# 4. Create a new App Password (name it "Website Contact Form") and paste it here
EMAIL_PASS=your-app-password-here
